# Environment Variables for Trading Signal System
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# ============================================================================
# DRY RUN MODE
# ============================================================================
# Set to 0 to actually send emails, 1 for dry-run (print only)
DRY_RUN=1

# ============================================================================
# ANTHROPIC API (for Claude Code CLI)
# ============================================================================
# Required if using Claude Code CLI for report generation
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# ============================================================================
# SMTP EMAIL SETTINGS
# ============================================================================
# SMTP server hostname (e.g., smtp.gmail.com, smtp.office365.com)
SMTP_HOST=smtp.gmail.com

# SMTP server port (587 for TLS, 465 for SSL, 25 for unencrypted)
SMTP_PORT=587

# SMTP username (usually your email address)
SMTP_USER=your-email@gmail.com

# SMTP password or app-specific password
# For Gmail: Use App Password (https://support.google.com/accounts/answer/185833)
# For Office365: Use your regular password or app password
SMTP_PASS=your-app-specific-password

# From address (usually same as SMTP_USER)
SMTP_FROM=your-email@gmail.com

# To address (recipient email, can be same as SMTP_USER)
SMTP_TO=your-email@gmail.com

# ============================================================================
# TWITTER/X API (optional, $100/month for Basic tier)
# ============================================================================
# Required for Twitter sentiment analysis
# Get from: https://developer.twitter.com/
TWITTER_BEARER_TOKEN=

# ============================================================================
# NEWS API (optional, free tier: 100 requests/day)
# ============================================================================
# Optional for enhanced news aggregation
# Get from: https://newsapi.org/
NEWSAPI_KEY=

# ============================================================================
# SEC EDGAR (required for SEC filings)
# ============================================================================
# SEC requires identifying User-Agent for API access
# Format: "AppName/Version (your-email@example.com)"
SEC_USER_AGENT=Tradz/1.0 (your-email@example.com)

# ============================================================================
# IBKR BROKER (optional)
# ============================================================================
# Only needed if broker integration is enabled
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# ============================================================================
# COMMON SMTP PROVIDERS
# ============================================================================
#
# Gmail:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   Note: Enable 2FA and use App Password
#
# Office365/Outlook:
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#
# Yahoo:
#   SMTP_HOST=smtp.mail.yahoo.com
#   SMTP_PORT=587
#   Note: Use App Password
#
# iCloud:
#   SMTP_HOST=smtp.mail.me.com
#   SMTP_PORT=587
#   Note: Use App-Specific Password
#
# SendGrid:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=your-sendgrid-api-key
#
# ============================================================================
